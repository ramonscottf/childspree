{
  "name": "childspree",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:create": "wrangler d1 create childspree-db",
    "db:migrate": "wrangler d1 execute childspree-db --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute childspree-db --local --file=schema.sql"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.4.0",
    "wrangler": "^3.0.0"
  }
}
